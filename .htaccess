# BEGIN V29 asset routing
# Rewrites /media/, /sequence/, /favicon/ to the theme folder so that
# the site's JS and HTML can reference assets with their original relative paths.
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /
RewriteRule ^(media|sequence|favicon)/(.*)$ /wp-content/themes/V29/$1/$2 [L]
</IfModule>
# END V29 asset routing

# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress
