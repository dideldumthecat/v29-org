{% extends "base.twig" %}

{% block content %}
    <h1 class="sr-only">V29 ist ein sozial-ökologisches Kollektivbauprojekt</h1>
        <div class="timeline-bg">
            <img id="bg-a" class="no-lazy">
            <img id="bg-b" class="no-lazy">
        </div>

        <section class="section top">
            <img class="title-video" id="title-webp-sequence" />

            <div class="timeline-controls">
                <button id="timeline-start">Start</button>
                <button id="timeline-today">Heute</button>
                <button id="timeline-zoom">Zoom</button>
                <button id="timeline-end">Info</button>
            </div>
        </section>

        <div class="today-line"></div>

        <section class="timeline-section">
            <div class="timeline-container">
                <div class="timeline" style="grid-template-columns: var(--first-col-width) repeat({{ columns|length }}, var(--month-width));">

                    {% set months = ['', 'Jän', 'Feb', 'Mär', 'Apr', 'Mai', 'Jun', 'Jul', 'Aug', 'Sep', 'Okt', 'Nov', 'Dez'] %}

                    <div class="cell header" style="grid-row: 1; grid-column: 1"></div>
                    {% for yh in year_headers %}
                        <div class="cell year{% if yh.span == 1 %} year-col{% endif %}"
                            style="grid-row: 1; grid-column: {{ yh.grid_column }} / span {{ yh.span }}">{{ yh.year }}</div>
                    {% endfor %}

                    <div class="cell header" style="grid-row: 2; grid-column: 1"></div>
                    {% for col in columns %}
                        <div class="cell header" style="grid-row: 2; grid-column: {{ loop.index + 1 }}">{% if col.kind == 'month' %}{{ months[col.month] }}{% endif %}</div>
                    {% endfor %}

                    <div class="cell info-cell" style="grid-column: 29 / span 1; grid-row: 3 / -1">
                        {{ about_content|raw }}
                        <p>
                            <a href="mailto:mail@v29.org">Kontakt</a>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                            <a href="#" id="impressum-link">Impressum</a>
                        </p>
                    </div>

                    {% for row in rows %}
                        <div class="cell row-title" style="grid-row: {{ row.grid_row }}; grid-column: 1">{{ row.title }}</div>

                        {% for item in row.items %}
                            {% if item.kind == 'media' %}
                                {% if item.thumb %}
                                    <div class="cell media-cell"
                                        style="grid-row: {{ row.grid_row }}; grid-column: {{ item.grid_column }} / span {{ item.span }}">
                                        {% if item.thumb.type == 'video' %}
                                            <video class="thumbnail no-lazy" src="{{ item.thumb.src }}" muted autoplay loop playsinline preload="auto"
                                                data-media="{{ item.media_json|e('html') }}"></video>
                                        {% else %}
                                            <img class="thumbnail no-lazy" src="{{ item.thumb.src }}" alt="{{ item.title }}"
                                                data-media="{{ item.media_json|e('html') }}" />
                                        {% endif %}
                                    </div>
                                {% endif %}
                            {% else %}
                                {% set cls = item.active ? 'cell active' : 'cell event' %}
                                {% if item.link %}
                                <a class="{{ cls }}" href="{{ item.link.url }}"{% if item.link.target %} target="{{ item.link.target }}"{% endif %}
                                    style="grid-row: {{ row.grid_row }}; grid-column: {{ item.grid_column }} / span {{ item.span }}">{{ item.body|raw }}</a>
                                {% else %}
                                <div class="{{ cls }}"
                                    style="grid-row: {{ row.grid_row }}; grid-column: {{ item.grid_column }} / span {{ item.span }}">{{ item.body|raw }}</div>
                                {% endif %}
                            {% endif %}
                        {% endfor %}

                    {% endfor %}

                </div>
            </div>
        </section>

        <div class="lightbox" id="lightbox">
            <div class="lightbox-track" id="lightbox-track"></div>
        </div>

        <div class="impressum-overlay" id="impressum-overlay">
            <div class="impressum-content">
                {{ impressum_content|raw }}
                <button class="impressum-close" id="impressum-close">Schließen</button>
            </div>
        </div>
{% endblock %}
